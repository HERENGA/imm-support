---
import Layout from '../layouts/Layout.astro';

const timeline = [
  {
    date: '2026年7月10日（金）',
    label: '公募開始',
    desc: '公募を開始します。申請システムが利用可能となり、書類の提出を受け付けます。',
    badge: 'open',
  },
  {
    date: '2026年8月31日（月）23:59',
    label: '申請締切',
    desc: '申請書類の受付を締め切ります。期限を過ぎた申請は受け付けられませんのでご注意ください。',
    badge: 'deadline',
  },
  {
    date: '2026年9〜10月',
    label: '対象可否確認・交付決定',
    desc: '事務局が応募要件への該当性を確認し、伴走支援補助の対象者を選定します。交付決定の通知を行います。',
    badge: 'review',
  },
  {
    date: '交付決定日〜2027年2月28日',
    label: '実績報告書提出',
    desc: '伴走支援を実施し、完了後に実績報告書を提出してください。補助対象期間内に活動を完了させる必要があります。',
    badge: 'report',
  },
  {
    date: '2027年3月',
    label: '補助金確定・精算',
    desc: '実績報告書の内容を確認の上、補助金額を確定し、精算払いを行います。',
    badge: 'payment',
  },
];

const badgeStyles: Record<string, string> = {
  open: 'bg-[#1B5E3B] text-white',
  deadline: 'bg-red-600 text-white',
  review: 'bg-[#C9A227] text-white',
  report: 'bg-blue-600 text-white',
  payment: 'bg-gray-600 text-white',
};
---

<Layout title="公募スケジュール">
  <!-- Hero banner -->
  <section class="bg-gradient-to-r from-[#1B5E3B] to-[#2d7a55] text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-green-300 mb-4">
        <a href="/" class="hover:text-white transition-colors">トップ</a>
        <span class="mx-2">/</span>
        <span class="text-white">公募スケジュール</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">公募スケジュール</h1>
      <p class="mt-3 text-green-100">公募から補助金確定までの全体スケジュールをご確認ください。</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Timeline -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-[#1B5E3B] rounded"></div>
          <h2 class="text-2xl font-bold text-gray-800">スケジュール一覧</h2>
        </div>

        <div class="relative">
          <!-- Vertical line -->
          <div class="absolute left-[22px] top-6 bottom-6 w-0.5 bg-gray-200 hidden md:block"></div>

          <div class="space-y-6">
            {timeline.map((item, index) => (
              <div class="flex gap-6">
                <!-- Circle indicator -->
                <div class="shrink-0 w-11 h-11 rounded-full border-4 border-[#1B5E3B] bg-white flex items-center justify-center z-10 hidden md:flex">
                  <span class="text-[#1B5E3B] font-bold text-sm">{index + 1}</span>
                </div>
                <!-- Content -->
                <div class="flex-1 bg-white border border-gray-200 rounded-lg p-6 shadow-sm hover:shadow-md transition-shadow">
                  <div class="flex flex-wrap items-start gap-3 mb-3">
                    <span class={`text-xs font-bold px-3 py-1 rounded-full ${badgeStyles[item.badge]}`}>
                      {item.label}
                    </span>
                    <span class="text-[#1B5E3B] font-bold text-sm pt-0.5">{item.date}</span>
                  </div>
                  <p class="text-sm text-gray-600 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Selection criteria -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-[#1B5E3B] rounded"></div>
          <h2 class="text-2xl font-bold text-gray-800">選定について</h2>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
          <div class="space-y-5 text-gray-700 leading-relaxed">
            <p>
              事務局は、インパクト証明書の一次審査の通過後、応募要件への該当性を確認した上で、提出された【様式１】及び見積書等に基づき、伴走支援補助の対象者を選定します。
            </p>
            <div class="bg-[#E8F4EC] border-l-4 border-[#1B5E3B] p-5 rounded-r-lg">
              <p class="font-medium text-[#1B5E3B]">
                本選定は、一次審査の結果（点数・順位）そのものを評価するものではなく、二次審査に向けて外部の伴走支援を受ける必要性と、その支援を担う伴走支援者の能力に着目して行います。
              </p>
            </div>
          </div>
        </div>
      </div>

      <!-- Key dates summary card -->
      <div class="bg-[#1B5E3B] text-white rounded-lg p-8">
        <h3 class="text-lg font-bold mb-6 flex items-center gap-2">
          <svg class="w-5 h-5 text-[#C9A227]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          重要日程サマリー
        </h3>
        <div class="grid md:grid-cols-2 gap-4 text-sm">
          <div class="bg-white/10 rounded-lg p-4">
            <p class="text-[#C9A227] font-bold mb-1">公募開始</p>
            <p>2026年7月10日（金）</p>
          </div>
          <div class="bg-white/10 rounded-lg p-4">
            <p class="text-[#C9A227] font-bold mb-1">申請締切</p>
            <p>2026年8月31日（月）23:59</p>
          </div>
          <div class="bg-white/10 rounded-lg p-4">
            <p class="text-[#C9A227] font-bold mb-1">実績報告書提出期限</p>
            <p>2027年2月28日</p>
          </div>
          <div class="bg-white/10 rounded-lg p-4">
            <p class="text-[#C9A227] font-bold mb-1">補助金確定・精算</p>
            <p>2027年3月</p>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/application"
          class="bg-[#1B5E3B] text-white px-6 py-3 rounded font-bold hover:bg-[#154d30] transition-colors"
        >
          申請方法を確認する
        </a>
        <a
          href="/contact"
          class="border border-[#1B5E3B] text-[#1B5E3B] px-6 py-3 rounded font-bold hover:bg-[#E8F4EC] transition-colors"
        >
          お問い合わせ
        </a>
      </div>
    </div>
  </section>
</Layout>
