---
import Layout from '../layouts/Layout.astro';

const documents = [
  {
    num: '1',
    title: '【様式１】伴走支援補助申請書',
    desc: '所定の様式に必要事項を記入の上、電子ファイルにて提出してください。様式は申請システムよりダウンロード可能です。',
  },
  {
    num: '2',
    title: '伴走支援者から受領した見積書等',
    desc: '【様式１】の参考資料として添付してください。伴走支援者から正式に受領した見積書等を使用してください。',
  },
  {
    num: '3',
    title: 'その他、事務局が必要と認める資料',
    desc: '審査の過程で追加書類の提出を求める場合があります。事務局からの連絡に速やかに対応いただくようお願いします。',
  },
];
---

<Layout title="申請方法">
  <!-- Hero banner -->
  <section class="bg-gradient-to-r from-[#1B5E3B] to-[#2d7a55] text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-green-300 mb-4">
        <a href="/" class="hover:text-white transition-colors">トップ</a>
        <span class="mx-2">/</span>
        <span class="text-white">申請方法</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">申請方法</h1>
      <p class="mt-3 text-green-100">提出書類の準備方法と申請手順をご確認ください。</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Important notice: apply online -->
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-5 mb-12 flex gap-3">
        <svg class="w-6 h-6 text-blue-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        <div>
          <p class="font-bold text-blue-800 mb-1">電子申請のみ受付</p>
          <p class="text-sm text-blue-700">
            申請書類の提出は、申請システムから電子ファイルにより提出してください。原本の送付は不要です。<strong>郵送及びFAXによる提出は受け付けません。</strong>
          </p>
        </div>
      </div>

      <!-- Documents -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-[#1B5E3B] rounded"></div>
          <h2 class="text-2xl font-bold text-gray-800">提出書類</h2>
        </div>

        <div class="space-y-4">
          {documents.map((doc) => (
            <div class="bg-white border border-gray-200 rounded-lg p-6 shadow-sm">
              <div class="flex items-start gap-4">
                <div class="shrink-0 w-8 h-8 bg-[#1B5E3B] text-white rounded-full flex items-center justify-center font-bold text-sm">
                  {doc.num}
                </div>
                <div>
                  <h3 class="font-bold text-gray-800 mb-2">{doc.title}</h3>
                  <p class="text-sm text-gray-600 leading-relaxed">{doc.desc}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- How to apply -->
      <div class="mb-12">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-[#1B5E3B] rounded"></div>
          <h2 class="text-2xl font-bold text-gray-800">申請方法の説明</h2>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg p-8 shadow-sm">
          <div class="space-y-6 text-gray-700 leading-relaxed">
            <p>
              申請書類の提出は、申請システムから電子ファイルにより提出してください。原本の送付は不要です。郵送及びFAXによる提出は受け付けません。
            </p>

            <div class="grid md:grid-cols-3 gap-4">
              <div class="bg-[#E8F4EC] rounded-lg p-4 text-center">
                <div class="text-[#1B5E3B] text-3xl font-bold mb-2">STEP 1</div>
                <p class="text-sm font-medium text-gray-700">インパクト証明書の発行申請と同時に【様式１】及び見積書等を提出</p>
              </div>
              <div class="bg-[#E8F4EC] rounded-lg p-4 text-center">
                <div class="text-[#1B5E3B] text-3xl font-bold mb-2">STEP 2</div>
                <p class="text-sm font-medium text-gray-700">一次審査の通過を確認</p>
              </div>
              <div class="bg-[#E8F4EC] rounded-lg p-4 text-center">
                <div class="text-[#1B5E3B] text-3xl font-bold mb-2">STEP 3</div>
                <p class="text-sm font-medium text-gray-700">事務局による伴走支援補助の対象者選定・交付決定</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Apply button -->
      <div class="bg-[#1B5E3B] rounded-lg p-8 text-white text-center">
        <h3 class="text-xl font-bold mb-3">申請システムへ</h3>
        <p class="text-green-200 text-sm mb-6">電子ファイルによる提出はこちらから</p>
        <a
          href="#"
          class="inline-block bg-[#C9A227] text-white px-10 py-3 rounded font-bold hover:bg-[#b8911f] transition-colors shadow-lg"
          title="申請システムURL（準備中）"
        >
          申請システムへアクセス（準備中）
        </a>
        <p class="text-xs text-green-300 mt-3">※申請システムは公募開始（2026年7月10日）以降に利用可能となります。</p>
      </div>

      <div class="mt-8 flex flex-wrap gap-4">
        <a
          href="/eligibility"
          class="border border-[#1B5E3B] text-[#1B5E3B] px-6 py-3 rounded font-bold hover:bg-[#E8F4EC] transition-colors"
        >
          補助対象者を確認する
        </a>
        <a
          href="/contact"
          class="border border-gray-300 text-gray-600 px-6 py-3 rounded font-bold hover:bg-gray-50 transition-colors"
        >
          お問い合わせ
        </a>
      </div>
    </div>
  </section>
</Layout>
