---
import Layout from '../layouts/Layout.astro';
---

<Layout title="お問い合わせ">
  <!-- Hero banner -->
  <section class="bg-gradient-to-r from-[#1B5E3B] to-[#2d7a55] text-white py-14 px-4">
    <div class="max-w-6xl mx-auto">
      <nav class="text-sm text-green-300 mb-4">
        <a href="/" class="hover:text-white transition-colors">トップ</a>
        <span class="mx-2">/</span>
        <span class="text-white">お問い合わせ</span>
      </nav>
      <h1 class="text-3xl md:text-4xl font-bold">お問い合わせ</h1>
      <p class="mt-3 text-green-100">ご不明な点は事務局までお気軽にお問い合わせください。</p>
    </div>
  </section>

  <section class="py-16 px-4">
    <div class="max-w-4xl mx-auto">

      <!-- Contact card -->
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-8">
          <div class="w-1 h-8 bg-[#1B5E3B] rounded"></div>
          <h2 class="text-2xl font-bold text-gray-800">事務局 連絡先</h2>
        </div>

        <div class="bg-white border border-gray-200 rounded-lg shadow-sm overflow-hidden">
          <!-- Header of card -->
          <div class="bg-[#1B5E3B] text-white px-8 py-5">
            <h3 class="font-bold text-lg leading-relaxed">
              「農山漁村振興への貢献活動に係るインパクト証明書」に関する企業等への伴走支援補助事業事務局
            </h3>
            <p class="text-green-200 text-sm mt-1">（株式会社JTB内）</p>
          </div>

          <!-- Contact details -->
          <div class="p-8">
            <!-- Staff -->
            <div class="mb-8 pb-8 border-b border-gray-100">
              <div class="flex items-start gap-4">
                <div class="shrink-0 text-[#1B5E3B]">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">担当者</p>
                  <p class="text-gray-800 font-medium">越智、齊藤、佐々木（健）、竹内</p>
                </div>
              </div>
            </div>

            <!-- Phone -->
            <div class="mb-8 pb-8 border-b border-gray-100">
              <div class="flex items-start gap-4">
                <div class="shrink-0 text-[#1B5E3B]">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">電話番号</p>
                  <a href="tel:03-6737-9270" class="text-xl font-bold text-[#1B5E3B] hover:underline">
                    03-6737-9270
                  </a>
                  <p class="text-sm text-gray-500 mt-1">受付時間：平日 9:30〜17:30</p>
                </div>
              </div>
            </div>

            <!-- Email -->
            <div>
              <div class="flex items-start gap-4">
                <div class="shrink-0 text-[#1B5E3B]">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div>
                  <p class="text-xs text-gray-500 font-medium uppercase tracking-wide mb-1">メールアドレス</p>
                  <a href="mailto:ppc_project@jtb.com" class="text-[#1B5E3B] font-bold text-lg hover:underline">
                    ppc_project@jtb.com
                  </a>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Additional notes -->
      <div class="bg-[#E8F4EC] rounded-lg p-6 mb-10">
        <h3 class="font-bold text-[#1B5E3B] mb-4">お問い合わせの際のご注意</h3>
        <ul class="space-y-2 text-sm text-gray-700">
          <li class="flex items-start gap-2">
            <span class="text-[#1B5E3B] font-bold shrink-0">▶</span>
            お問い合わせは電話またはメールにて承ります。
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#1B5E3B] font-bold shrink-0">▶</span>
            メールでのお問い合わせには、件名に「インパクト証明書 伴走支援補助事業 問い合わせ」とご記入ください。
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#1B5E3B] font-bold shrink-0">▶</span>
            受付時間外のお問い合わせは、翌営業日以降にご回答いたします。
          </li>
          <li class="flex items-start gap-2">
            <span class="text-[#1B5E3B] font-bold shrink-0">▶</span>
            申請システムに関するお問い合わせも上記事務局にて承ります。
          </li>
        </ul>
      </div>

      <!-- Attribution -->
      <div class="border border-gray-200 rounded-lg p-6 text-center">
        <p class="text-sm text-gray-500 mb-2">本事業の主管</p>
        <p class="font-bold text-gray-800">農林水産省</p>
        <p class="text-sm text-gray-500 mt-1">令和8年度 農山漁村振興交付金事業</p>
      </div>

    </div>
  </section>
</Layout>
